DJANGO_SETTINGS_MODULE=project.settings.develop
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
DATABASE_URL=sqlite:///db.sqlite3

# Bitrix24 CRM webhook (format: https://your-domain.bitrix24.ua/rest/{user_id}/{webhook_code})
BITRIX_WEBHOOK_URL=https://your-domain.bitrix24.ua/rest/1/your-webhook-code

# Google Tag Manager
GTM_CONTAINER_ID=GTM-XXXXXXX

# Cloudinary (for carousel images)
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret
CLOUDINARY_URL=cloudinary://your-api-key:your-api-secret@your-cloud-name

# Gmail SMTP
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@wingo.com.ua

# Production only
# CSRF_TRUSTED_ORIGINS=https://landing.wingo.com.ua
